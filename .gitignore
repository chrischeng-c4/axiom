.DS_Store
Thumbs.db

# Environment
.env
.env.*
!.env.example
target/
# cross-build target dir (Linux), same regenerable build output as target/
/target-linux/

.claude/settings.local.json
.claude/scheduled_tasks.lock

# Frontend build artifacts
dist/
node_modules/
.jet/
.vite/
projects/cue/fe/.jet/
projects/cue/artifact-studio/.jet/
projects/cue/be/static/*
!projects/cue/be/static/.gitkeep
projects/cue/backend/static/*
!projects/cue/backend/static/.gitkeep
pkg/
crates/data-bridge-sheet-wasm/pkg/
tests/fixtures/python-project/.venv/

# MCP config (local-specific paths)
.mcp.json

# Playwright MCP artifacts
.playwright-mcp/
test-results/
.aw/worktrees/
.aw/payloads/
.aw/codegen_markers.yaml
.claude/worktrees/

# tdc local state
.tdc/state.toml

# CPython conformance fixtures use test.support.os_helper, whose TESTFN
# (= "@test_<pid>_tmp" + a non-ASCII suffix) and companion artifacts are
# created RELATIVE TO THE CWD. When a fixture/harness runs with cwd = repo
# root these leak here. The real fix is running fixtures in an isolated
# tempdir (see run.py / regen_golden.py / tests/cpython/harness/*.rs), but
# this is a belt-and-suspenders guard so a stray leak is never committed.
@test_*_tmp*
# test.support TESTFN (src/runtime/stdlib/support_mod.rs uses "@mamba_test_<pid>",
# a separate relative name from os_helper's "@test_*_tmp"); same CWD leak.
@mamba_test_*
# os_helper sibling artifacts (anchored to repo root only). Remove if a
# legitimate root-level base/ or file.txt is ever introduced.
/base/
/file.txt

# mamba conformance perf-baseline cache (derived; regenerates from fixtures)
projects/mamba/tests/cpython/.cache/

# cargo-mutants output
mutants.out
mutants.out.old
.rig/
# arena per-run report cache + baseline store written under the cwd
.arena/
