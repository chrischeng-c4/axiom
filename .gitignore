# Lens daemon index and runtime files
.aw/.index/
.aw/issues/

# qc per-run report cache (.qc/last-report.json) — written under the cwd a qc
# verb runs in (often the repo root); process output, never source.
.qc/

# meter per-run report cache (.meter/last-report.json) — written under the cwd a
# meter verb runs in (often the repo root); process output, never source.
.meter/

# guard per-run report cache (.guard/last-report.json); process output, never
# source. Waiver config (.guard/waivers.json) IS source — keep it tracked.
.guard/*
!.guard/waivers.json

# Tool-local runtime state such as GH device ids; process-local, never source.
.local/

# keep's default data dir (WAL + snapshots) — written under the cwd when keep runs
# without KEEP_DATA_DIR set (e.g. from the repo root in an ad-hoc run). Runtime
# store, never source. e2e scripts point KEEP_DATA_DIR at /tmp; this catches strays.
/data/

# vat copy-on-write workspaces and run state; process output, never source.
.vat/

# ctx_inf_db autonomous loop runtime state (transitional — not versioned)
.ctx_inf_db.state
.ctx_inf_db/

# Benchmark results
.benchmarks/
.baselines/
**/benchmarks/results/
!**/benchmarks/results/.gitkeep
**/benchmark_report*
**/reports/*_benchmark_report*

# Coverage reports
*coverage_report*
htmlcov/
.coverage

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
# `build/` above is Python build output; the jet test block named build/ is source.
!projects/jet/tests/build/
!projects/jet/tests/build/**
.pytest_cache/

# Virtual environments
venv/
.venv/
ENV/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

