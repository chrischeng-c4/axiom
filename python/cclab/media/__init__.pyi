import enum

class PixelFormat(enum.IntEnum):
    Gray = ...
    Rgb = ...
    Rgba = ...
    Hsv = ...
    Lab = ...

class BlendMode(enum.IntEnum):
    Normal = ...
    Multiply = ...
    Screen = ...
    Overlay = ...
    Add = ...
    Difference = ...

class Image:
    def __init__(self, width: int, height: int, format: PixelFormat = PixelFormat.Rgb) -> None: ...
    @staticmethod
    def from_raw(data: bytes, width: int, height: int, format: PixelFormat) -> Image: ...
    @staticmethod
    def decode(data: bytes) -> Image: ...
    def encode(self, format: str = "png") -> bytes: ...
    @property
    def width(self) -> int: ...
    @property
    def height(self) -> int: ...
    @property
    def format(self) -> PixelFormat: ...
    @property
    def data(self) -> bytes: ...
    def n_pixels(self) -> int: ...
    def get_pixel(self, x: int, y: int) -> list[int]: ...
    def set_pixel(self, x: int, y: int, pixel: list[int]) -> None: ...
    # Color conversions
    def to_gray(self) -> Image: ...
    def to_rgb(self) -> Image: ...
    def to_hsv(self) -> Image: ...
    def to_lab(self) -> Image: ...
    # Edge detection
    def sobel(self) -> Image: ...
    def canny(self, low_thresh: float, high_thresh: float) -> Image: ...
    # Histogram
    def histogram(self) -> list[int]: ...
    def equalize(self) -> Image: ...
    def clahe(self, tile_w: int, tile_h: int, clip_limit: float) -> Image: ...
    # Blending
    def alpha_blend(self, other: Image, alpha: float) -> Image: ...
    def blend(self, other: Image, mode: BlendMode, opacity: float) -> Image: ...
    def composite(self, other: Image, x: int, y: int, opacity: float) -> Image: ...
    # Filters
    def gaussian_blur(self) -> Image: ...
    def sharpen(self) -> Image: ...
    # Morphology
    def dilate(self, kernel_size: int) -> Image: ...
    def erode(self, kernel_size: int) -> Image: ...
    def median_blur(self, kernel_size: int) -> Image: ...
    # Transforms
    def resize(self, width: int, height: int, interpolation: str = "nearest") -> Image: ...
    def crop(self, x: int, y: int, w: int, h: int) -> Image: ...
    def flip_horizontal(self) -> Image: ...
    def flip_vertical(self) -> Image: ...
    def rotate90(self) -> Image: ...
    def adjust_brightness(self, delta: int) -> Image: ...
    def adjust_contrast(self, factor: float) -> Image: ...
    def threshold(self, thresh: int) -> Image: ...

class Frame:
    def __init__(self, width: int, height: int) -> None: ...
    @staticmethod
    def from_raw(data: bytes, width: int, height: int, timestamp: float, index: int) -> Frame: ...
    @property
    def width(self) -> int: ...
    @property
    def height(self) -> int: ...
    @property
    def timestamp(self) -> float: ...
    @property
    def index(self) -> int: ...
    @property
    def data(self) -> bytes: ...
    def get_pixel(self, x: int, y: int) -> tuple[int, int, int]: ...

class VideoMeta:
    @property
    def width(self) -> int: ...
    @property
    def height(self) -> int: ...
    @property
    def fps(self) -> float: ...
    @property
    def frame_count(self) -> int: ...
    @property
    def duration(self) -> float: ...
    @property
    def codec(self) -> str: ...

class VideoReader:
    @staticmethod
    def from_raw(data: bytes, width: int, height: int, fps: float) -> VideoReader: ...
    def meta(self) -> VideoMeta: ...
    def frame_count(self) -> int: ...
    def duration(self) -> float: ...
    def fps(self) -> float: ...
    def next_frame(self) -> Frame: ...

class VideoWriter:
    def __init__(self, width: int, height: int, fps: float) -> None: ...
    def write_frame(self, frame: Frame) -> None: ...
    def frame_count(self) -> int: ...
    def meta(self) -> VideoMeta: ...
    def finalize(self) -> bytes: ...

class SampleFormat(enum.IntEnum):
    I16 = ...
    F32 = ...

class AudioTrack:
    @staticmethod
    def from_samples(samples: list[float], sample_rate: int, channels: int) -> AudioTrack: ...
    @staticmethod
    def silence(sample_rate: int, channels: int, duration: float) -> AudioTrack: ...
    @staticmethod
    def from_pcm(data: bytes, sample_rate: int, channels: int, format: SampleFormat) -> AudioTrack: ...
    @property
    def sample_rate(self) -> int: ...
    @property
    def channels(self) -> int: ...
    @property
    def duration(self) -> float: ...
    @property
    def samples(self) -> list[float]: ...
    def samples_per_channel(self) -> int: ...
    def get_channel(self, channel: int) -> list[float]: ...
    def to_mono(self) -> AudioTrack: ...
    def resample(self, target_rate: int) -> AudioTrack: ...
    def adjust_volume(self, factor: float) -> AudioTrack: ...
    def trim(self, start: float, end: float) -> AudioTrack: ...
    def fade_in(self, duration: float) -> AudioTrack: ...
    def fade_out(self, duration: float) -> AudioTrack: ...
    def rms_energy(self) -> float: ...
    def peak_detect(self, threshold: float) -> list[int]: ...

class PdfDocument:
    def __init__(self) -> None: ...
    def set_title(self, title: str) -> None: ...
    def set_author(self, author: str) -> None: ...
    def add_page(self, page: PdfPage) -> None: ...
    @property
    def page_count(self) -> int: ...
    def generate(self) -> bytes: ...
    def save(self, path: str) -> None: ...

class PdfPage:
    def __init__(self) -> None: ...
    def set_size(self, width: float, height: float) -> None: ...
    def set_size_a4(self) -> None: ...
    def set_size_letter(self) -> None: ...
    def set_margins(self, top: float, right: float, bottom: float, left: float) -> None: ...
    def set_uniform_margins(self, margin: float) -> None: ...
    def add_text(self, text: str, font_size: float, font: str = "Helvetica", align: str = "left") -> None: ...

class image:
    PixelFormat = PixelFormat
    BlendMode = BlendMode
    Image = Image

class video:
    Frame = Frame
    VideoMeta = VideoMeta
    VideoReader = VideoReader
    VideoWriter = VideoWriter

class audio:
    SampleFormat = SampleFormat
    AudioTrack = AudioTrack

class pdf:
    PdfDocument = PdfDocument
    PdfPage = PdfPage
