from typing import Optional

class LinearRegression:
    def __init__(self, fit_intercept: bool = True) -> None: ...
    def fit(self, x: list[float], n_features: int, y: list[float]) -> None: ...
    def predict(self, x: list[float], n_features: int) -> list[float]: ...
    def score(self, x: list[float], n_features: int, y: list[float]) -> float: ...
    @property
    def weights(self) -> Optional[list[float]]: ...
    @property
    def intercept(self) -> Optional[float]: ...

class RidgeRegression:
    def __init__(self, alpha: float = 1.0) -> None: ...
    def fit(self, x: list[float], n_features: int, y: list[float]) -> None: ...
    def predict(self, x: list[float], n_features: int) -> list[float]: ...
    @property
    def weights(self) -> Optional[list[float]]: ...

class LassoRegression:
    def __init__(self, alpha: float = 1.0) -> None: ...
    def fit(self, x: list[float], n_features: int, y: list[float]) -> None: ...
    def predict(self, x: list[float], n_features: int) -> list[float]: ...
    @property
    def weights(self) -> Optional[list[float]]: ...

class PolynomialFeatures:
    def __init__(self, degree: int = 2, include_bias: bool = True, interaction_only: bool = False) -> None: ...
    def fit(self, x: list[float], n_features: int) -> None: ...
    def transform(self, x: list[float], n_features: int) -> list[float]: ...
    def fit_transform(self, x: list[float], n_features: int) -> list[float]: ...
    @property
    def n_output_features(self) -> Optional[int]: ...

class CountVectorizer:
    def __init__(self, max_features: Optional[int] = None) -> None: ...
    def fit(self, documents: list[str]) -> None: ...
    def transform(self, documents: list[str]) -> tuple[list[float], int]: ...
    def fit_transform(self, documents: list[str]) -> tuple[list[float], int]: ...
    @property
    def vocab_size(self) -> Optional[int]: ...

class Tensor:
    def __init__(self, data: list[float], shape: list[int]) -> None: ...
    @staticmethod
    def zeros(shape: list[int]) -> Tensor: ...
    @staticmethod
    def ones(shape: list[int]) -> Tensor: ...
    @staticmethod
    def randn(shape: list[int], seed: int) -> Tensor: ...
    @property
    def data(self) -> list[float]: ...
    @property
    def shape(self) -> list[int]: ...
    def numel(self) -> int: ...
    def ndim(self) -> int: ...
    def sum(self) -> float: ...
    def mean(self) -> float: ...
    def add(self, other: Tensor) -> Tensor: ...
    def sub(self, other: Tensor) -> Tensor: ...
    def mul(self, other: Tensor) -> Tensor: ...
    def scale(self, s: float) -> Tensor: ...

class ml:
    LinearRegression = LinearRegression
    RidgeRegression = RidgeRegression
    LassoRegression = LassoRegression
    PolynomialFeatures = PolynomialFeatures
    CountVectorizer = CountVectorizer

class dl:
    Tensor = Tensor
