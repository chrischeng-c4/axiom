class Gemini:
    def __init__(self, api_key: str, default_model: str | None = None) -> None:
        ...
    @property
    def provider_name(self) -> str:
        ...
    def supported_models(self) -> list[str]:
        ...
    def complete(self, messages: list[Any], model: str | None = None, temperature: float | None = None, max_tokens: int | None = None, tools: list[Any] | None = None) -> Any:
