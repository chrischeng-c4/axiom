class ToolParameter:
    name: str
    description: str
    required: bool
    parameter_type: str
    def __init__(self, name: str, description: str, parameter_type: str, required: bool = True) -> None:
        ...
    def __repr__(self) -> str:
        ...

class Tool:
    def __init__(self, name: str, description: str, callback: Any, parameters: list[Any] | None = None) -> None:
        ...
    @property
    def name(self) -> str:
        ...
    @property
    def description(self) -> str:
        ...
    @property
    def parameters(self) -> list[Any]:
        ...
    def execute(self, arguments: Any) -> Any:
        ...
    def __repr__(self) -> str:
        ...

class ToolRegistry:
    def __init__(self) -> None:
        ...
    def register(self, tool: Any) -> None:
        """Register a tool"""
        ...
    def unregister(self, name: str) -> None:
        """Unregister a tool by name"""
        ...
    def contains(self, name: str) -> bool:
        """Check if a tool is registered"""
        ...
    def tool_names(self) -> list[str]:
        """Get all tool names"""
        ...
    def count(self) -> int:
        """Get the number of registered tools"""
        ...
    def clear(self) -> None:
        """Clear all registered tools"""
        ...
    def execute(self, name: str, arguments: Any) -> Any:
        """Execute a tool by name"""
        ...
    def get_definitions(self) -> Any:
        """Get tool definitions for LLM"""
        ...
    def __repr__(self) -> str:
        ...
    def __len__(self) -> int:
        ...
    def __contains__(self, name: str) -> bool:
        ...

