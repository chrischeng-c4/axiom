from typing import Any

__all__ = ["Message", "CompletionResponse", "OpenAI", "Claude", "Gemini", "ToolParameter", "Tool", "ToolRegistry"]

class Message:
    def __init__(self, role: str, content: str, name: str | None = None, tool_call_id: str | None = None) -> None:
        ...
    @staticmethod
    def system(content: str) -> Any:
        ...
    @staticmethod
    def user(content: str) -> Any:
        ...
    @staticmethod
    def assistant(content: str) -> Any:
        ...
    @staticmethod
    def tool(tool_call_id: str, content: str) -> Any:
        ...
    @property
    def role(self) -> str:
        ...
    @property
    def content(self) -> str:
        ...
    @property
    def name(self) -> str | None:
        ...
    @property
    def tool_call_id(self) -> str | None:
        ...
    def __repr__(self) -> str:
        ...

class CompletionResponse:
    content: str
    finish_reason: str
    model: str
    prompt_tokens: int
    completion_tokens: int
    total_tokens: int
    @property
    def tool_calls(self) -> Any | None:
        ...
    def __repr__(self) -> str:
        ...

class OpenAI:
    def __init__(self, api_key: str, default_model: str | None = None) -> None:
        ...
    @property
    def provider_name(self) -> str:
        ...
    def supported_models(self) -> list[str]:
        ...
    def complete(self, messages: list[Any], model: str | None = None, temperature: float | None = None, max_tokens: int | None = None, tools: list[Any] | None = None) -> Any:
        ...
    def __repr__(self) -> str:
        ...

