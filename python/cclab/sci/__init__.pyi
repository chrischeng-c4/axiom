from typing import Optional

class TestResult:
    @property
    def statistic(self) -> float: ...
    @property
    def pvalue(self) -> float: ...
    def is_significant(self, alpha: float = 0.05) -> bool: ...

class DescribeResult:
    @property
    def count(self) -> int: ...
    @property
    def mean(self) -> float: ...
    @property
    def std(self) -> float: ...
    @property
    def min(self) -> float: ...
    @property
    def q1(self) -> float: ...
    @property
    def median(self) -> float: ...
    @property
    def q3(self) -> float: ...
    @property
    def max(self) -> float: ...
    @property
    def skewness(self) -> float: ...
    @property
    def kurtosis(self) -> float: ...

class ArimaModel:
    def __init__(self, data: list[float], p: int, d: int, q: int) -> None: ...
    @property
    def ar_coeffs(self) -> list[float]: ...
    @property
    def ma_coeffs(self) -> list[float]: ...
    @property
    def intercept(self) -> float: ...
    def forecast(self, h: int) -> list[float]: ...
    def fitted_values(self) -> list[float]: ...
    def aic(self) -> float: ...

class DecomposeResult:
    @property
    def observed(self) -> list[float]: ...
    @property
    def trend(self) -> list[float]: ...
    @property
    def seasonal(self) -> list[float]: ...
    @property
    def residual(self) -> list[float]: ...
    @property
    def period(self) -> int: ...
    def trend_strength(self) -> float: ...
    def seasonal_strength(self) -> float: ...

class CsrMatrix:
    def __init__(self, data: list[float], nrows: int, ncols: int) -> None: ...
    @staticmethod
    def from_coo(nrows: int, ncols: int, rows: list[int], cols: list[int], values: list[float]) -> CsrMatrix: ...
    @staticmethod
    def eye(n: int) -> CsrMatrix: ...
    def get(self, row: int, col: int) -> float: ...
    def to_dense(self) -> list[float]: ...
    def dot(self, x: list[float]) -> list[float]: ...
    def add(self, other: CsrMatrix) -> CsrMatrix: ...
    def scale(self, alpha: float) -> CsrMatrix: ...
    def transpose(self) -> CsrMatrix: ...

class KDTree:
    def __init__(self, points: list[list[float]]) -> None: ...
    def query(self, point: list[float], k: int) -> list[Neighbor]: ...
    def query_radius(self, point: list[float], radius: float) -> list[Neighbor]: ...

class Neighbor:
    @property
    def index(self) -> int: ...
    @property
    def distance(self) -> float: ...

class stats:
    @staticmethod
    def describe(data: list[float]) -> DescribeResult: ...
    @staticmethod
    def skew(data: list[float]) -> float: ...
    @staticmethod
    def kurtosis(data: list[float]) -> float: ...
    @staticmethod
    def zscore(data: list[float]) -> list[float]: ...
    @staticmethod
    def mode(data: list[float]) -> Optional[float]: ...
    @staticmethod
    def median(data: list[float]) -> Optional[float]: ...
    @staticmethod
    def iqr(data: list[float]) -> Optional[float]: ...
    @staticmethod
    def percentile(data: list[float], p: float) -> Optional[float]: ...

class fft:
    @staticmethod
    def fft_forward(data: list[tuple[float, float]]) -> list[tuple[float, float]]: ...
    @staticmethod
    def ifft_backward(data: list[tuple[float, float]]) -> list[tuple[float, float]]: ...
    @staticmethod
    def rfft_forward(data: list[float]) -> list[tuple[float, float]]: ...
    @staticmethod
    def irfft_backward(data: list[tuple[float, float]], n: int) -> list[float]: ...
    @staticmethod
    def fftfreq(n: int, d: float) -> list[float]: ...
    @staticmethod
    def rfftfreq(n: int, d: float) -> list[float]: ...

class spatial:
    @staticmethod
    def euclidean(a: list[float], b: list[float]) -> float: ...
    @staticmethod
    def manhattan(a: list[float], b: list[float]) -> float: ...
    @staticmethod
    def cosine_distance(a: list[float], b: list[float]) -> float: ...
    @staticmethod
    def pdist(points: list[list[float]], metric: str = "euclidean") -> list[float]: ...
    @staticmethod
    def cdist(xa: list[list[float]], xb: list[list[float]], metric: str = "euclidean") -> list[float]: ...
