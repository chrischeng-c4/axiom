from typing import Any, Callable, Optional

class LruCache:
    def __init__(self, max_size: int, ttl_secs: Optional[float] = None) -> None: ...
    def put(self, key: str, value: Any) -> Optional[Any]: ...
    def get(self, key: str) -> Optional[Any]: ...
    def remove(self, key: str) -> Optional[Any]: ...
    def contains_key(self, key: str) -> bool: ...
    def __len__(self) -> int: ...
    def clear(self) -> None: ...
    def purge_expired(self) -> None: ...
    @property
    def capacity(self) -> int: ...

# Humanize
def intcomma(value: int) -> str: ...
def intword(value: int) -> str: ...
def ordinal(value: int) -> str: ...
def apnumber(value: int) -> str: ...
def naturaltime(seconds: float) -> str: ...
def naturaldelta(seconds: float) -> str: ...
def naturalsize(value: float) -> str: ...

# Iteration
def chunked(data: list[Any], chunk_size: int) -> list[list[Any]]: ...
def windowed(data: list[Any], window_size: int) -> list[list[Any]]: ...
def first(data: list[Any]) -> Optional[Any]: ...
def one(data: list[Any]) -> Any: ...
def pairwise(data: list[Any]) -> list[tuple[Any, Any]]: ...
def partition(data: list[Any], predicate: Callable[..., bool]) -> tuple[list[Any], list[Any]]: ...
def flatten(data: list[list[Any]]) -> list[Any]: ...
def every_nth(data: list[Any], n: int) -> list[Any]: ...
def interleave(a: list[Any], b: list[Any]) -> list[Any]: ...
