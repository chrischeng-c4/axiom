from typing import Any, Optional

class HttpResponse:
    @property
    def status_code(self) -> int: ...
    @property
    def latency_ms(self) -> int: ...
    @property
    def url(self) -> str: ...
    def is_success(self) -> bool: ...
    def is_client_error(self) -> bool: ...
    def is_server_error(self) -> bool: ...
    def text(self) -> str: ...
    def json(self) -> Any: ...
    def bytes(self) -> bytes: ...
    def content_length(self) -> int: ...
    def header(self, name: str) -> Optional[str]: ...
    def content_type(self) -> Optional[str]: ...

class HttpClient:
    def __init__(
        self,
        base_url: Optional[str] = None,
        timeout: float = 30.0,
        connect_timeout: float = 10.0,
        pool_max_idle_per_host: int = 10,
        follow_redirects: bool = True,
        max_redirects: int = 10,
        user_agent: Optional[str] = None,
        danger_accept_invalid_certs: bool = False,
    ) -> None: ...
    @property
    def base_url(self) -> Optional[str]: ...
    async def get(self, path: str, headers: Optional[dict[str, str]] = None, params: Optional[dict[str, str]] = None, timeout: Optional[float] = None) -> HttpResponse: ...
    async def post(self, path: str, headers: Optional[dict[str, str]] = None, params: Optional[dict[str, str]] = None, json: Any = None, form: Optional[dict[str, str]] = None, multipart: Optional[dict[str, Any]] = None, timeout: Optional[float] = None) -> HttpResponse: ...
    async def put(self, path: str, headers: Optional[dict[str, str]] = None, params: Optional[dict[str, str]] = None, json: Any = None, form: Optional[dict[str, str]] = None, multipart: Optional[dict[str, Any]] = None, timeout: Optional[float] = None) -> HttpResponse: ...
    async def patch(self, path: str, headers: Optional[dict[str, str]] = None, params: Optional[dict[str, str]] = None, json: Any = None, form: Optional[dict[str, str]] = None, multipart: Optional[dict[str, Any]] = None, timeout: Optional[float] = None) -> HttpResponse: ...
    async def delete(self, path: str, headers: Optional[dict[str, str]] = None, params: Optional[dict[str, str]] = None, timeout: Optional[float] = None) -> HttpResponse: ...
    async def head(self, path: str, headers: Optional[dict[str, str]] = None, params: Optional[dict[str, str]] = None, timeout: Optional[float] = None) -> HttpResponse: ...
    async def options(self, path: str, headers: Optional[dict[str, str]] = None, params: Optional[dict[str, str]] = None, timeout: Optional[float] = None) -> HttpResponse: ...
