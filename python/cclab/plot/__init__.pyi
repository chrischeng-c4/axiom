from typing import Optional

class Chart:
    def __init__(self) -> None: ...
    def title(self, title: str) -> None: ...
    def size(self, width: float, height: float) -> None: ...
    def x_label(self, label: str) -> None: ...
    def y_label(self, label: str) -> None: ...
    def theme(self, name: str) -> None: ...
    def add_line(self, x: list[float], y: list[float], label: Optional[str] = None) -> None: ...
    def add_bar(self, labels: list[str], values: list[float]) -> None: ...
    def add_scatter(self, x: list[float], y: list[float], label: Optional[str] = None) -> None: ...
    def add_histogram(self, data: list[float], bins: int) -> None: ...
    def add_box_plot(self, data: list[list[float]], labels: list[str]) -> None: ...
    def add_heatmap(self, data: list[list[float]]) -> None: ...
    def add_pie(self, labels: list[str], values: list[float]) -> None: ...
