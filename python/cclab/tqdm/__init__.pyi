from typing import Any, Iterable, Iterator, Optional, TypeVar

T = TypeVar("T")

class tqdm(Iterator[T]):
    def __init__(
        self,
        iterable: Iterable[T],
        desc: Optional[str] = None,
        total: Optional[int] = None,
        disable: bool = False,
    ) -> None: ...
    def __iter__(self) -> "tqdm[T]": ...
    def __next__(self) -> T: ...
    def update(self, n: int = 1) -> None: ...
    def set_description(self, desc: str) -> None: ...
    def set_postfix_str(self, postfix: str) -> None: ...
    def close(self) -> None: ...
    @property
    def elapsed(self) -> float: ...
    @property
    def rate(self) -> float: ...
    @property
    def n(self) -> int: ...
    @property
    def total(self) -> Optional[int]: ...

class ProgressBar:
    def __init__(self, total: int = 100) -> None: ...
    def update(self, n: int = 1) -> None: ...
    def set_description(self, desc: str) -> None: ...
    def close(self) -> None: ...

def trange(n: int, desc: Optional[str] = None) -> tqdm[int]: ...
