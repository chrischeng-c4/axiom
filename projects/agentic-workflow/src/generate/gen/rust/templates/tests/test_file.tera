{{ member_indent }}{{ attr }}
{%- endfor %}
{{ member_indent }}{{ t.visibility }}{{ t.async_prefix }}fn {{ t.name }}(){{ t.return_type }} {
{{ t.body }}
{{ member_indent }}}

{% endfor -%}
{%- if postamble != "" %}
{{ postamble }}
{%- endif %}
