{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://jet.cclab/parity/schemas/ax-tree-normalised.schema.json",
  "title": "NormalisedAxTreeArtifact",
  "type": "object",
  "required": ["schema_version", "fixture_id", "renderer", "captured_at", "root"],
  "properties": {
    "schema_version": {"const": 1},
    "fixture_id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "renderer": {"enum": ["jet-webgpu", "jet-html", "react-dom-mui"]},
    "captured_at": {"type": "string", "format": "date-time"},
    "root": {"$ref": "#/$defs/node"}
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["path", "role", "ignored"],
      "properties": {
        "path": {"type": "string", "pattern": "^([0-9]+(/[0-9]+)*)?$"},
        "role": {"type": "string"},
        "name": {"type": "string"},
        "value": {"type": "string"},
        "description": {"type": "string"},
        "ignored": {"type": "boolean"},
        "properties": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "value"],
            "properties": {
              "name": {"enum": [
                "disabled","checked","selected","expanded","pressed","level",
                "multiline","multiselectable","orientation","readonly","required",
                "valuemin","valuemax","valuenow","valuetext","haspopup","live",
                "relevant","atomic","busy","controls","describedby","flowto",
                "labelledby","owns"
              ]},
              "value": {}
            },
            "additionalProperties": false
          }
        },
        "children": {"type": "array", "items": {"$ref": "#/$defs/node"}}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
