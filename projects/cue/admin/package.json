{
  "name": "cue-admin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../artifact-studio/scripts/jet.mjs dev --host 127.0.0.1 --port 3216",
    "dev:vite": "vite --host 127.0.0.1 --port 3216",
    "build": "node ../artifact-studio/scripts/jet.mjs build -o ../backend/static/admin",
    "build:vite": "vite build --outDir ../backend/static/admin --emptyOutDir",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "typescript": "^5.3.3",
    "vite": "^5.4.11"
  }
}
