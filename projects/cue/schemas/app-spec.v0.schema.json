{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cclab.dev/cue/app-spec/v0",
  "title": "Cue App Spec v0",
  "description": "Versioned manifest for governed internal work apps generated and operated by cue.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "app",
    "users",
    "data",
    "permissions",
    "workflow",
    "automation",
    "dashboard",
    "audit",
    "tests",
    "deployment"
  ],
  "properties": {
    "schema_version": {
      "const": "cue.app-spec.v0"
    },
    "app": {
      "$ref": "#/$defs/app"
    },
    "users": {
      "$ref": "#/$defs/users"
    },
    "data": {
      "$ref": "#/$defs/data"
    },
    "permissions": {
      "$ref": "#/$defs/permissions"
    },
    "workflow": {
      "$ref": "#/$defs/workflow"
    },
    "automation": {
      "$ref": "#/$defs/automation"
    },
    "dashboard": {
      "$ref": "#/$defs/dashboard"
    },
    "audit": {
      "$ref": "#/$defs/audit"
    },
    "tests": {
      "$ref": "#/$defs/tests"
    },
    "deployment": {
      "$ref": "#/$defs/deployment"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "app_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,62}$"
    },
    "app": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "description",
        "goal",
        "owner_team",
        "owner_user",
        "risk_tier",
        "lifecycle_status"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/app_id"
        },
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "description": {
          "$ref": "#/$defs/non_empty_string"
        },
        "goal": {
          "$ref": "#/$defs/goal"
        },
        "owner_team": {
          "$ref": "#/$defs/non_empty_string"
        },
        "owner_user": {
          "$ref": "#/$defs/non_empty_string"
        },
        "risk_tier": {
          "enum": ["tier_0", "tier_1", "tier_2", "tier_3", "tier_4"]
        },
        "lifecycle_status": {
          "enum": ["draft", "sandbox", "production", "archived", "retired"]
        }
      }
    },
    "goal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "problem", "success_metrics", "review_policy"],
      "properties": {
        "statement": {
          "$ref": "#/$defs/non_empty_string"
        },
        "problem": {
          "$ref": "#/$defs/non_empty_string"
        },
        "success_metrics": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/success_metric"
          }
        },
        "review_policy": {
          "$ref": "#/$defs/review_policy"
        }
      }
    },
    "success_metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "baseline", "target", "window"],
      "properties": {
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "baseline": {
          "type": ["string", "number", "null"]
        },
        "target": {
          "type": ["string", "number"]
        },
        "window": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "review_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cadence", "owner_required"],
      "properties": {
        "cadence": {
          "enum": ["monthly", "quarterly", "custom"]
        },
        "owner_required": {
          "const": true
        }
      }
    },
    "users": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_users"],
      "properties": {
        "target_users": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/target_user"
          }
        }
      }
    },
    "target_user": {
      "type": "object",
      "additionalProperties": false,
      "required": ["team", "role"],
      "properties": {
        "team": {
          "$ref": "#/$defs/non_empty_string"
        },
        "role": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entities", "data_sources"],
      "properties": {
        "entities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/entity"
          }
        },
        "data_sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/data_source"
          }
        }
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "fields"],
      "properties": {
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/field"
          }
        }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "required", "sensitivity"],
      "properties": {
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "type": {
          "enum": [
            "string",
            "text",
            "integer",
            "number",
            "boolean",
            "date",
            "datetime",
            "email",
            "url",
            "enum",
            "user",
            "team",
            "attachment"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "sensitivity": {
          "enum": ["public", "internal", "confidential", "restricted"]
        },
        "enum_values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      }
    },
    "data_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_name", "access_type", "data_owner"],
      "properties": {
        "source_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "access_type": {
          "enum": ["read", "write", "read_write"]
        },
        "data_owner": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["roles"],
      "properties": {
        "roles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/role"
          }
        }
      }
    },
    "role": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "permissions"],
      "properties": {
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "permissions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/permission"
          }
        }
      }
    },
    "permission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "scope"],
      "properties": {
        "action": {
          "enum": ["view", "create", "edit", "delete", "approve", "export"]
        },
        "scope": {
          "enum": ["app", "entity", "field", "record"]
        },
        "resource": {
          "$ref": "#/$defs/non_empty_string"
        },
        "condition": {
          "type": ["string", "null"]
        }
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["states", "transitions"],
      "properties": {
        "states": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/workflow_state"
          }
        },
        "transitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/workflow_transition"
          }
        }
      }
    },
    "workflow_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type"],
      "properties": {
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "type": {
          "enum": ["start", "intermediate", "terminal"]
        }
      }
    },
    "workflow_transition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "condition", "actor_role"],
      "properties": {
        "from": {
          "$ref": "#/$defs/non_empty_string"
        },
        "to": {
          "$ref": "#/$defs/non_empty_string"
        },
        "condition": {
          "type": ["string", "null"]
        },
        "actor_role": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "automation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["triggers"],
      "properties": {
        "triggers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/automation_trigger"
          }
        }
      }
    },
    "automation_trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "condition", "actions"],
      "properties": {
        "type": {
          "enum": ["schedule", "event", "state_change", "manual"]
        },
        "condition": {
          "type": ["string", "null"]
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/automation_action"
          }
        }
      }
    },
    "automation_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "enum": ["notify", "create_task", "update_record", "request_approval"]
        },
        "target": {
          "type": ["string", "null"]
        },
        "payload": {
          "type": "object"
        }
      }
    },
    "dashboard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["views"],
      "properties": {
        "views": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dashboard_view"
          }
        }
      }
    },
    "dashboard_view": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "metrics"],
      "properties": {
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "metrics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dashboard_metric"
          }
        }
      }
    },
    "dashboard_metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "formula"],
      "properties": {
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "formula": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "retention_days", "log_events"],
      "properties": {
        "enabled": {
          "const": true
        },
        "retention_days": {
          "type": "integer",
          "minimum": 30
        },
        "log_events": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      }
    },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_tests"],
      "properties": {
        "required_tests": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "permission_test",
              "workflow_test",
              "data_validation_test",
              "policy_test",
              "regression_test"
            ]
          }
        }
      }
    },
    "deployment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["environments", "approval_required"],
      "properties": {
        "environments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": ["sandbox", "production"]
          }
        },
        "approval_required": {
          "type": "array",
          "items": {
            "enum": ["app_owner", "team_manager", "data_owner", "security", "legal"]
          }
        }
      }
    }
  }
}
