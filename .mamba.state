      change_id: mamba-frozenset-r3-content-hash
      scope: "R3 frozenset content-based __hash__ only — mb_hash FrozenSet arm in builtins.rs, multiply-then-XOR with 47-bit truncation. All 4 R-groups of parent bug now shipped."
      commit: fcfe089f
      completed_at: 2026-04-16T07:34:30Z
      agent: aa42df78272d9cbba
      partial_completion: false
      closes_parent_bug: true
